@page
@model WorkoutTracker.Api.Pages.Exercises.ExercisesIndexModel
@{
    ViewData["Title"] = "Exercises";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Exercises</h2>
    <a href="/Exercises/Create" class="btn btn-dark">+ Add Exercise</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Exercises.Any())
{
    <div class="alert alert-secondary">No exercises yet. Add one to get started.</div>
}
else
{
    <div class="row g-3">
        @foreach (var exercise in Model.Exercises)
        {
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title mb-1">@exercise.Name</h6>
                        <span class="badge bg-secondary">@exercise.MuscleGroup</span>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <a href="/Exercises/Details?exerciseId=@exercise.Id" class="btn btn-sm btn-dark">Details</a>
                            <a href="/Exercises/Edit?exerciseId=@exercise.Id" class="btn btn-sm btn-outline-dark">Edit</a>
                            <a href="/Exercises/History?exerciseId=@exercise.Id" class="btn btn-sm btn-outline-dark">History</a>
                            <form method="post" asp-page-handler="Delete"
                                  onsubmit="return confirm('Delete @exercise.Name? This cannot be undone.')">
                                <input type="hidden" name="exerciseId" value="@exercise.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
