@page
@model WorkoutTracker.Api.Pages.Exercises.ExerciseHistoryModel
@{
    ViewData["Title"] = "Exercise History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>History: @Model.ExerciseName</h2>
    <a href="/Exercises" class="btn btn-outline-secondary">← Back</a>
</div>

@if (!Model.Sets.Any())
{
    <div class="alert alert-secondary">No sets logged for this exercise yet.</div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Set #</th>
                <th>Weight (kg)</th>
                <th>Reps</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var set in Model.Sets)
            {
                <tr>
                    <td>@set.SetNumber</td>
                    <td>@set.Weight</td>
                    <td>@set.Reps</td>
                </tr>
            }
        </tbody>
    </table>
}
